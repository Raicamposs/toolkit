#!/usr/bin/env sh

commit_msg=$(cat "$1")
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?(!)?: .{1,100}'

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "  ✖ Commit message fora do padrão Conventional Commits."
  echo ""
  echo "  Formato esperado:  <tipo>(<escopo opcional>): <descrição>"
  echo "  Tipos válidos:     feat | fix | docs | style | refactor | perf | test | build | ci | chore | revert"
  echo ""
  echo "  Exemplos:"
  echo "    feat(auth): add JWT refresh token"
  echo "    fix: handle null value in numberParse"
  echo "    docs: update README with new array utils"
  echo ""
  echo "  Use 'npm run commit' para o prompt interativo."
  echo ""
  exit 1
fi
